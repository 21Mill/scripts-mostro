# ============================================================================
# Mostro Scripts — Configuración
# Copia este archivo como .env y edita los valores, o ejecuta ./setup.sh
# ============================================================================

# --- mostrod ---
#MOSTROD_SRC=/opt/mostro
#MOSTROD_CONFIG=/opt/mostro/settings.toml
#MOSTROD_BIN=/usr/local/bin/mostrod
#MOSTROD_SERVICE=mostro.service

# --- mostrix ---
#MOSTRIX_SRC=~/mostro-sources/mostrix
#MOSTRIX_CONFIG=~/.mostrix/settings.toml
#MOSTRIX_BIN=/usr/local/bin/mostrix

# --- mostro-watchdog ---
#WATCHDOG_SRC=~/mostro-sources/mostro-watchdog
#WATCHDOG_CONFIG=/opt/mostro/config.toml
#WATCHDOG_BIN=/usr/local/bin/mostro-watchdog
#WATCHDOG_SERVICE=mostro-watchdog.service

# --- General ---
#BACKUP_DIR=~/mostro-sources/backups
#MOSTRO_DB=/opt/mostro/mostro.db
#MOSTRO_LOG=                          # Vacío = journalctl
#BOT_SERVICE=mostrobot.service

# --- Telegram ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TEST_CHAT_ID=

# --- Mostro Nostr ---
MOSTRO_PUBKEY=
MOSTRO_RELAY=wss://relay.mostro.network
